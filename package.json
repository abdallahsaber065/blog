{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx prisma generate && next build",
    "build:leapcell": "npx prisma generate && next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "dev": "dotenv -c -- next dev -p 3444",
    "start": "dotenv -c -- next start",
    "start:leapcell": "npx prisma migrate deploy &&node .next/standalone/server.js",
    "lint": "next lint",
    "create-admin": "dotenv -c -- node scripts/create-admin.js",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "db:reset": "prisma migrate reset --force",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "images:convert": "node scripts/convert-images-to-webp.js",
    "images:convert:delete": "node scripts/convert-images-to-webp.js --delete-originals",
    "images:update-db": "node scripts/update-post-images.js && node scripts/update-profile-images.js"
  },
